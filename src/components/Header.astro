---
import { DarkModeToggle } from "selo-components";
import { LanguageToggle } from "selo-components";

const navbar = [
  ["/", "Home"],
  ["/blog", "Blog"],
];
const lang = Astro.url.pathname.split("/")[1];
/* LANGUAGE CHANGE BUTTON
const localeRoot =
  !config.use_language_toggle || lang == "en" ? "/" : `/${lang}`;
*/
---

<style>
  header {
    position: relative;
    max-width: 850px;
    text-align: center;
    border-bottom: 5px dotted var(--accent);
    padding: 20px 0;
    margin: auto;
    margin-top: 10px;
  }
  img {
    max-width: 100%;
    max-height: 150px;
  }
  a:has(img) {
    display: block; /*fix focus styling on main header*/
  }
  a {
    text-decoration: none;
    /* color: var(--txt); */
  }
</style>

<header>
  {
    <div style="font-weight: 700">
      {navbar
        .map(([url, label]) =>
          Astro.url.pathname == url ? (
            <span>{label}</span>
          ) : (
            <a href={url}>{label}</a>
          ),
        )
        .reduce((prev, curr, i) => (
          <>
            {prev} {" · "} {curr}
          </>
        ))}
    </div>
  }
  <!--LANGUAGE CHANGE BUTTON
  <a href={localeRoot}>
    <img alt={config.hostname} src="/header.svg" />
  </a>
  <DarkModeToggle />
  {config.use_language_toggle && <LanguageToggle />}
  <slot />
  
</header>
